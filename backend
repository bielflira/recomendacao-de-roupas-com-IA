from fastapi import FastAPI, UploadFile
import shutil
from ia import analisar_imagem
from scraper import buscar_produtos

app = FastAPI()

@app.post("/buscar")
async def buscar(file: UploadFile):
    path = f"temp/{file.filename}"

    with open(path, "wb") as buffer:
        shutil.copyfileobj(file.file, buffer)

    descricao = analisar_imagem(path)
    produtos = buscar_produtos(descricao)

    return {
        "descricao": descricao,
        "produtos": produtos
    }
